{{- /* Realise the language runtimes declared in dot_config/mise/config.toml. */ -}}
#!/usr/bin/env bash
set -euo pipefail

log()  { printf '\033[1;36m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m  %s\n' "$*" >&2; }

if ! command -v mise >/dev/null 2>&1; then
  warn "mise not on PATH — skipping runtime install"
  exit 0
fi

# Re-run trigger: any change to the chosen runtimes mutates this hash, which
# in turn changes the rendered script's content, which makes chezmoi re-run us.
# runtimes: {{ .runtimes | sortAlpha | join "," }}

{{ if not .runtimes -}}
log "no runtimes selected at chezmoi init — skipping mise install"
log "to add runtimes later: edit ~/.config/chezmoi/chezmoi.toml or run 'mise use -g <runtime>@<version>'"
{{- else -}}
log "mise install (global tools): {{ .runtimes | sortAlpha | join ", " }}"
mise install --quiet || warn "some tools failed; run \`mise doctor\` to investigate"
mise reshim
{{- end }}
